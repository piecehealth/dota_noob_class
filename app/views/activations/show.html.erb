<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-full max-w-sm bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold mb-1">激活账号</h2>
      <p class="text-base-content/60 mb-4">
        欢迎，
        <% if @user.classroom %>第 <%= @user.classroom.number %> 班<% end %>
        <% if @user.group %>第 <%= @user.group.number %> 组<% end %>
        <%= @user.role_name %>
        <strong><%= @user.display_name %></strong>！请设置您的登录用户名和密码。
      </p>

      <% if flash[:alert] %>
        <div role="alert" class="alert alert-error mb-4">
          <span><%= flash[:alert] %></span>
        </div>
      <% end %>

      <%= form_with model: @user, url: activation_path(@user.activation_token), method: :patch do |f| %>
        <fieldset class="fieldset">
          <label class="fieldset-label" for="username">用户名（登录用）</label>
          <%= f.text_field :username, id: "username", class: "input input-bordered w-full", placeholder: "设置登录用户名", required: true, autocomplete: "username" %>
        </fieldset>

        <fieldset class="fieldset mt-3">
          <label class="fieldset-label" for="password">密码</label>
          <%= f.password_field :password, id: "password", class: "input input-bordered w-full", placeholder: "至少 6 位", required: true %>
        </fieldset>

        <fieldset class="fieldset mt-3">
          <label class="fieldset-label" for="password_confirmation">确认密码</label>
          <%= f.password_field :password_confirmation, id: "password_confirmation", class: "input input-bordered w-full", placeholder: "再次输入密码", required: true %>
        </fieldset>

        <div class="mt-6">
          <%= f.submit "激活并登录", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
