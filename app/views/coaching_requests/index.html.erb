<div class="py-6 px-3 sm:px-6">
  <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">
    <div class="p-4 sm:p-8">
      <h1 class="text-2xl font-bold mb-6">复盘请求</h1>

      <% if @coaching_requests.empty? %>
        <div class="alert">暂无待处理的复盘请求</div>
      <% else %>
        <div class="flex flex-col gap-3">
          <% @coaching_requests.each do |cr| %>
            <% hero = Hero.find_by_id(cr.match.hero_id) %>
            <% hero_key = hero&.name&.sub("npc_dota_hero_", "") %>
            <div class="flex items-center gap-3 sm:gap-4 p-3 rounded-xl border border-base-200 hover:bg-base-50">
              <%# Hero portrait %>
              <div class="w-12 h-12 shrink-0 rounded-lg overflow-hidden bg-base-200">
                <% if hero_key %>
                  <%= image_tag "heros/#{hero_key}.png", class: "w-full h-full object-cover", alt: hero&.cn_name %>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center text-xs text-base-content/40">?</div>
                <% end %>
              </div>

              <%# Student info %>
              <div class="min-w-[100px]">
                <div class="font-semibold text-sm"><%= cr.student.display_name %></div>
                <div class="text-xs text-base-content/50">第 <%= cr.student.group&.number %> 组</div>
              </div>

              <%# Hero + match info %>
              <div class="hidden sm:block text-sm text-base-content/70">
                <%= hero&.cn_name || "未知英雄" %>
              </div>

              <%# Own group badge %>
              <% if cr.student.group_id == current_user.group_id %>
                <span class="badge badge-primary badge-sm">本组</span>
              <% end %>

              <%# Status badge %>
              <% status_class = cr.requested? ? "badge-warning" : "badge-info" %>
              <span class="badge <%= status_class %> badge-sm">
                <%= cr.requested? ? "待认领" : "复盘中" %>
              </span>

              <%# Actions %>
              <div class="ml-auto flex gap-2">
                <%= link_to "查看", match_coaching_request_path(cr.match),
                      class: "btn btn-sm btn-ghost" %>
                <% if cr.requested? %>
                  <%= button_to "认领", claim_match_coaching_request_path(cr.match),
                        method: :patch, class: "btn btn-sm btn-primary" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
