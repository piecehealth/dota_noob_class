<div class="py-6 px-3 sm:px-6">
  <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">
    <div class="p-4 sm:p-8">
      <h1 class="text-2xl font-bold mb-6">我的复盘</h1>

      <% if @coaching_requests.empty? %>
        <div class="alert">暂无复盘请求</div>
      <% else %>
        <% status_labels = { "requested" => "待认领", "in_progress" => "复盘中", "completed" => "已完成" } %>
        <% status_classes = { "requested" => "badge-warning", "in_progress" => "badge-info", "completed" => "badge-success" } %>
        <div class="flex flex-col gap-3">
          <% @coaching_requests.each do |cr| %>
            <% hero = Hero.find_by_id(cr.match.hero_id) %>
            <% hero_key = hero&.name&.sub("npc_dota_hero_", "") %>
            <div class="flex items-center gap-3 sm:gap-4 p-3 rounded-xl border border-base-200 hover:bg-base-50">
              <div class="w-12 h-12 shrink-0 rounded-lg overflow-hidden bg-base-200">
                <% if hero_key %>
                  <%= image_tag "heros/#{hero_key}.png", class: "w-full h-full object-cover", alt: hero&.cn_name %>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center text-xs text-base-content/40">?</div>
                <% end %>
              </div>

              <div class="min-w-[90px]">
                <div class="font-semibold text-sm"><%= hero&.cn_name || "未知英雄" %></div>
                <div class="text-xs text-base-content/30 font-mono">#<%= cr.match.match_id %></div>
              </div>

              <span class="badge <%= status_classes[cr.status] %> badge-sm">
                <%= status_labels[cr.status] %>
              </span>

              <div class="ml-auto flex gap-2">
                <%= link_to "查看复盘", match_coaching_request_path(cr.match),
                      class: "btn btn-sm btn-ghost" %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
