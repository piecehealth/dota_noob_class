<!DOCTYPE html>
<html data-theme="dark">
  <head>
    <title><%= content_for(:title) || "Dota2 萌新班" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-base-100 min-h-screen">
    <!-- Flash Messages -->
    <% if notice %>
      <div class="toast toast-top toast-center z-50">
        <div class="alert alert-success">
          <span><%= notice %></span>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="toast toast-top toast-center z-50">
        <div class="alert alert-error">
          <span><%= alert %></span>
        </div>
      </div>
    <% end %>

    <!-- Simple Header -->
    <div class="bg-base-200 border-b border-base-300 p-4">
      <div class="container mx-auto flex justify-between items-center">
        <h1 class="text-xl font-bold">
          <%= link_to "Dota2 萌新班", root_path, class: "hover:opacity-80" %>
        </h1>
        <div class="flex gap-4 text-sm">
          <%= link_to "👥 学员", students_stats_path, class: "hover:opacity-80" %>
          <%= link_to "🎮 对局", matches_path, class: "hover:opacity-80" %>
          <%= link_to "📅 往期排行榜", history_leaderboards_path, class: "hover:opacity-80" %>
        </div>
      </div>
    </div>

    <!-- Content -->
    <%= yield %>
  </body>
</html>
