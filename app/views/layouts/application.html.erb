<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dota Noob Class" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Dota Noob Class">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen bg-primary" data-theme="cupcake">
    <%= render "shared/header" %>

    <% if notice %>
      <div class="toast toast-top toast-center z-50 pt-2">
        <div class="alert alert-success flex items-center gap-2 pr-2">
          <span><%= notice %></span>
          <button onclick="this.closest('.toast').remove()" class="btn btn-ghost btn-xs">✕</button>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="toast toast-top toast-center z-50 pt-2">
        <div class="alert alert-error flex items-center gap-2 pr-2">
          <span><%= alert %></span>
          <button onclick="this.closest('.toast').remove()" class="btn btn-ghost btn-xs">✕</button>
        </div>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
