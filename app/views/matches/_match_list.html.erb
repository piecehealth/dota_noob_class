<% if matches.empty? %>
  <div class="alert">暂无对战记录</div>
<% else %>
  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>对局</th>
          <th>英雄表现</th>
          <th>结果</th>
        </tr>
      </thead>
      <tbody>
        <% matches.each do |mp| %>
          <% match = mp.match %>
          <tr class="<%= mp.won ? 'bg-success/10' : 'bg-error/10' %>">
            <!-- 对局信息 -->
            <td class="whitespace-nowrap">
              <div class="text-xs font-mono opacity-70">
                <%= link_to match.match_id, match_path(match), class: "hover:underline" %>
              </div>
              <div class="text-xs opacity-50">
                <%= match.played_at&.in_time_zone('Beijing')&.strftime("%m-%d %H:%M") %>
              </div>
              <div class="flex gap-1 mt-1">
                <span class="badge badge-ghost badge-xs"><%= match.lobby_type_name %></span>
                <span class="badge badge-ghost badge-xs"><%= match.duration_formatted %></span>
                <% if mp.party_size && mp.party_size > 1 %>
                  <span class="badge badge-primary badge-xs"><%= mp.party_size %>排</span>
                <% end %>
              </div>
            </td>

            <!-- 英雄表现 -->
            <td>
              <div class="flex items-center gap-3">
                <%= image_tag mp.hero_image_path, 
                              alt: mp.hero_name, 
                              class: "w-10 h-10 rounded object-cover",
                              onerror: "this.src='/assets/heros/placeholder.svg'" %>
                <div>
                  <div class="text-sm font-medium"><%= mp.hero_name %></div>
                  <div class="font-mono text-sm opacity-70">
                    <%= mp.kills %>/<%= mp.deaths %>/<%= mp.assists %>
                  </div>
                  <div class="flex gap-1 mt-0.5">
                    <% if mp.lane_outcome %>
                      <span class="badge <%= mp.lane_outcome_badge_class %> badge-xs"><%= mp.lane_outcome_name %></span>
                    <% end %>
                    <% if mp.award.present? && mp.award != "NONE" %>
                      <span class="badge <%= mp.award_badge_class %> badge-xs"><%= mp.award_text %></span>
                    <% end %>
                  </div>
                </div>
              </div>
            </td>

            <!-- 结果 -->
            <td>
              <div class="badge <%= mp.won ? 'badge-success' : 'badge-error' %> badge-lg">
                <%= mp.won ? '胜' : '负' %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
