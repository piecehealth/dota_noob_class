<div class="container mx-auto p-4">
  <h1 class="text-2xl font-bold mb-4">🎮 对局列表</h1>

  <!-- Filters -->
  <div class="card bg-base-200 mb-4">
    <div class="card-body py-4">
      <%= form_with url: matches_path, method: :get, class: "flex flex-wrap items-center gap-3" do |f| %>
        <div class="flex items-center gap-2">
          <label class="text-sm whitespace-nowrap">班级:</label>
          <%= f.select :classroom_id, 
              options_for_select(@classrooms.map { |c| ["#{c.number}班", c.id] }, params[:classroom_id]),
              { include_blank: "全部" },
              class: "select select-bordered select-sm w-28",
              onchange: "this.form.submit()" %>
        </div>
        
        <div class="flex items-center gap-2">
          <label class="text-sm whitespace-nowrap">小组:</label>
          <%= f.select :group_id,
              options_for_select(@groups.map { |g| ["#{g.number}组", g.id] }, params[:group_id]),
              { include_blank: "全部" },
              class: "select select-bordered select-sm w-28",
              disabled: @groups.empty?,
              onchange: "this.form.submit()" %>
        </div>
        
        <div class="flex items-center gap-2 ml-auto">
          <%= link_to "清除", matches_path, class: "btn btn-ghost btn-sm" if params[:classroom_id].present? || params[:group_id].present? %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card bg-base-200">
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>对局</th>
            <th>玩家</th>
            <th>英雄表现</th>
            <th>结果</th>
          </tr>
        </thead>
        <tbody>
          <% @match_players.each do |mp| %>
            <tr class="<%= mp.won ? 'bg-success/10' : 'bg-error/10' %>">
              <!-- 对局信息 -->
              <td class="whitespace-nowrap">
                <div class="text-xs font-mono opacity-70">
                  <%= link_to mp.match.match_id, match_path(mp.match), class: "hover:underline" %>
                </div>
                <div class="text-xs opacity-50">
                  <%= mp.match.played_at&.in_time_zone('Beijing')&.strftime("%m-%d %H:%M") %>
                </div>
                <div class="flex gap-1 mt-1">
                  <span class="badge badge-ghost badge-xs whitespace-nowrap"><%= mp.match.lobby_type_name %></span>
                  <span class="badge badge-ghost badge-xs whitespace-nowrap"><%= mp.match.duration_formatted %></span>
                  <% if mp.party_size && mp.party_size > 1 %>
                    <span class="badge badge-primary badge-xs whitespace-nowrap"><%= mp.party_size %>排</span>
                  <% end %>
                </div>
              </td>

              <!-- 玩家信息 -->
              <td>
                <div class="font-medium">
                  <%= link_to mp.user.display_name || mp.user.username, 
                      matches_user_path(mp.user),
                      class: "link link-primary" %>
                </div>
                <% if mp.user.classroom || mp.user.group %>
                  <div class="text-xs opacity-50">
                    <% if mp.user.classroom %>
                      <%= link_to "#{mp.user.classroom.number}班", classroom_stats_path(mp.user.classroom),
                          class: "hover:underline" %>
                    <% end %>
                    <% if mp.user.group %>
                      <%= link_to "#{mp.user.group.number}组", group_stats_path(mp.user.group),
                          class: "hover:underline" %>
                    <% end %>
                  </div>
                <% end %>
                <div class="flex gap-1 mt-1">
                  <% if mp.on_radiant %>
                    <span class="badge badge-warning badge-xs whitespace-nowrap">天辉</span>
                  <% else %>
                    <span class="badge badge-info badge-xs whitespace-nowrap">夜魇</span>
                  <% end %>
                  <span class="badge badge-outline badge-xs whitespace-nowrap"><%= mp.position_role %></span>
                </div>
              </td>

              <!-- 英雄表现 -->
              <td>
                <div class="flex items-center gap-3">
                  <%= image_tag mp.hero_image_path, 
                                alt: mp.hero_name, 
                                class: "w-10 h-10 rounded object-cover",
                                onerror: "this.src='/assets/heros/placeholder.svg'" %>
                  <div>
                    <div class="text-sm font-medium"><%= mp.hero_name %></div>
                    <div class="font-mono text-sm opacity-70">
                      <%= mp.kills %>/<%= mp.deaths %>/<%= mp.assists %>
                    </div>
                    <div class="flex gap-1 mt-0.5">
                      <% if mp.lane_outcome %>
                        <span class="badge <%= mp.lane_outcome_badge_class %> badge-xs whitespace-nowrap"><%= mp.lane_outcome_name %></span>
                      <% end %>
                      <% if mp.award.present? && mp.award != "NONE" %>
                        <span class="badge <%= mp.award_badge_class %> badge-xs whitespace-nowrap"><%= mp.award_text %></span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </td>

              <!-- 结果 -->
              <td>
                <div class="badge <%= mp.won ? 'badge-success' : 'badge-error' %> badge-lg whitespace-nowrap">
                  <%= mp.won ? '胜' : '负' %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-6">
    <%= paginate @match_players if @match_players.respond_to?(:total_pages) %>
  </div>
</div>
