<div class="container mx-auto p-4">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to "←", root_path, class: "btn btn-ghost btn-sm" %>
    <h1 class="text-2xl font-bold">我的对局</h1>
  </div>

  <div class="card bg-base-200">
    <div class="card-body">
      <%= render "matches/match_list", matches: @matches %>
    </div>
  </div>

  <%= paginate @matches %>
</div>
