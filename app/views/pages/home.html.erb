<div class="container mx-auto p-4">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold">🏆 本周排行榜</h1>
      <p class="text-sm opacity-60">
        <%= @week_start.strftime("%m月%d日") %> - <%= @week_end.strftime("%m月%d日") %>
      </p>
    </div>
  </div>

  <!-- Summary Stats (Big Numbers) -->
  <div class="stats shadow w-full mb-8">
    <div class="stat bg-primary/10">
      <div class="stat-title">本周活跃玩家</div>
      <div class="stat-value text-primary"><%= @summary[:active_players] %></div>
      <div class="stat-desc">有对局记录的玩家</div>
    </div>
    <div class="stat bg-secondary/10">
      <div class="stat-title">本周总场次</div>
      <div class="stat-value text-secondary"><%= @summary[:matches_total] %></div>
      <div class="stat-desc">所有模式对局</div>
    </div>
    <div class="stat bg-accent/10">
      <div class="stat-title">本周排位场次</div>
      <div class="stat-value text-accent"><%= @summary[:matches_ranked] %></div>
      <div class="stat-desc">天梯匹配对局</div>
    </div>
  </div>

  <!-- Leaderboards Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    
    <!-- 冲分榜 - 段位提升最多 -->
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">
          <span class="text-warning">📈</span> 冲分榜
          <span class="text-xs font-normal opacity-50">段位提升</span>
        </h2>
        <% if @top_players_by_rank.any? %>
          <div class="space-y-2">
            <% @top_players_by_rank.each do |entry| %>
              <div class="flex items-center gap-3 p-2 bg-base-100 rounded-lg">
                <div class="w-8 h-8 flex items-center justify-center font-bold <%= entry.rank <= 3 ? 'text-warning' : 'opacity-50' %>">
                  <%= entry.rank <= 3 ? ["🥇", "🥈", "🥉"][entry.rank - 1] : "##{entry.rank}" %>
                </div>
                <div class="flex-1 min-w-0">
                  <% if entry.entity_type == "User" && entry.entity %>
                    <%= link_to entry.entity_name, matches_user_path(entry.entity), class: "font-medium truncate block link link-primary" %>
                  <% else %>
                    <span class="font-medium truncate block"><%= entry.entity_name %></span>
                  <% end %>
                  <div class="text-xs opacity-50">
                    <% if entry.classroom %>
                      <%= link_to "#{entry.classroom.name}", classroom_stats_path(entry.classroom), class: "hover:underline" %>
                    <% end %>
                    <% if entry.group %>
                      <%= link_to "#{entry.group.number}组", group_stats_path(entry.group), class: "hover:underline" %>
                    <% end %>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-success font-bold">+<%= entry.value %>级</div>
                  <% if entry.details %>
                    <div class="text-xs opacity-50" title="<%= entry.details['start_display'] %> → <%= entry.details['end_display'] %>">
                      <%= entry.details['start_display'] %> → <%= entry.details['end_display'] %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 opacity-50">
            <p>本周暂无段位变化记录</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 玩家场次榜 -->
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">
          <span class="text-info">🎮</span> 酬勤榜
          <span class="text-xs font-normal opacity-50">对局最多</span>
        </h2>
        <% if @top_players_by_matches.any? %>
          <div class="space-y-2">
            <% @top_players_by_matches.each do |entry| %>
              <div class="flex items-center gap-3 p-2 bg-base-100 rounded-lg">
                <div class="w-8 h-8 flex items-center justify-center font-bold <%= entry.rank <= 3 ? 'text-warning' : 'opacity-50' %>">
                  <%= entry.rank <= 3 ? ["🥇", "🥈", "🥉"][entry.rank - 1] : "##{entry.rank}" %>
                </div>
                <div class="flex-1 min-w-0">
                  <% if entry.entity_type == "User" && entry.entity %>
                    <%= link_to entry.entity_name, matches_user_path(entry.entity), class: "font-medium truncate block link link-primary" %>
                  <% else %>
                    <span class="font-medium truncate block"><%= entry.entity_name %></span>
                  <% end %>
                  <div class="text-xs opacity-50">
                    <% if entry.classroom %>
                      <%= link_to "#{entry.classroom.name}", classroom_stats_path(entry.classroom), class: "hover:underline" %>
                    <% end %>
                    <% if entry.group %>
                      <%= link_to "#{entry.group.number}组", group_stats_path(entry.group), class: "hover:underline" %>
                    <% end %>
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-bold text-lg"><%= entry.value %>场</div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 opacity-50">
            <p>本周暂无对局记录</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- KDA榜 -->
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">
          <span class="text-success">⚔️</span> KDA榜
          <span class="text-xs font-normal opacity-50">场均KDA (至少3场)</span>
        </h2>
        <%= render 'shared/kda_leaderboard', entries: @top_players_by_kda %>
      </div>
    </div>

    <!-- 击杀榜 -->
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">
          <span class="text-error">💀</span> 击杀榜
          <span class="text-xs font-normal opacity-50">总击杀数</span>
        </h2>
        <% if @top_players_by_kills.any? %>
          <div class="space-y-2">
            <% @top_players_by_kills.each do |entry| %>
              <div class="flex items-center gap-3 p-2 bg-base-100 rounded-lg">
                <div class="w-8 h-8 flex items-center justify-center font-bold <%= entry.rank <= 3 ? 'text-warning' : 'opacity-50' %>">
                  <%= entry.rank <= 3 ? ["🥇", "🥈", "🥉"][entry.rank - 1] : "##{entry.rank}" %>
                </div>
                <div class="flex-1 min-w-0">
                  <% if entry.entity_type == "User" && entry.entity %>
                    <%= link_to entry.entity_name, matches_user_path(entry.entity), class: "font-medium truncate block link link-primary" %>
                  <% else %>
                    <span class="font-medium truncate block"><%= entry.entity_name %></span>
                  <% end %>
                  <div class="text-xs opacity-50">
                    <% if entry.classroom %>
                      <%= link_to "#{entry.classroom.name}", classroom_stats_path(entry.classroom), class: "hover:underline" %>
                    <% end %>
                    <% if entry.group %>
                      <%= link_to "#{entry.group.number}组", group_stats_path(entry.group), class: "hover:underline" %>
                    <% end %>
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-bold text-error text-lg"><%= entry.value %></div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 opacity-50">
            <p>本周暂无击杀数据</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- MVP榜 -->
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">
          <span class="text-warning">👑</span> MVP榜
          <span class="text-xs font-normal opacity-50">MVP+最佳核心+最佳辅助</span>
        </h2>
        <% if @top_players_by_mvps.any? %>
          <div class="space-y-2">
            <% @top_players_by_mvps.each do |entry| %>
              <div class="flex items-center gap-3 p-2 bg-base-100 rounded-lg">
                <div class="w-8 h-8 flex items-center justify-center font-bold <%= entry.rank <= 3 ? 'text-warning' : 'opacity-50' %>">
                  <%= entry.rank <= 3 ? ["🥇", "🥈", "🥉"][entry.rank - 1] : "##{entry.rank}" %>
                </div>
                <div class="flex-1 min-w-0">
                  <% if entry.entity_type == "User" && entry.entity %>
                    <%= link_to entry.entity_name, matches_user_path(entry.entity), class: "font-medium truncate block link link-primary" %>
                  <% else %>
                    <span class="font-medium truncate block"><%= entry.entity_name %></span>
                  <% end %>
                  <div class="text-xs opacity-50">
                    <% if entry.classroom %>
                      <%= link_to "#{entry.classroom.name}", classroom_stats_path(entry.classroom), class: "hover:underline" %>
                    <% end %>
                    <% if entry.group %>
                      <%= link_to "#{entry.group.number}组", group_stats_path(entry.group), class: "hover:underline" %>
                    <% end %>
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-bold text-warning text-lg"><%= entry.value %></div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 opacity-50">
            <p>本周暂无MVP记录</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 班级榜 -->
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">
          <span class="text-primary">🏫</span> 酬勤班级榜
          <span class="text-xs font-normal opacity-50">对局总数</span>
        </h2>
        <% if @top_classrooms.any? %>
          <div class="space-y-2">
            <% @top_classrooms.each do |entry| %>
              <div class="flex items-center gap-3 p-2 bg-base-100 rounded-lg">
                <div class="w-8 h-8 flex items-center justify-center font-bold <%= entry.rank <= 3 ? 'text-warning' : 'opacity-50' %>">
                  <%= entry.rank <= 3 ? ["🥇", "🥈", "🥉"][entry.rank - 1] : "##{entry.rank}" %>
                </div>
                <div class="flex-1 min-w-0">
                  <% if entry.entity_type == "Classroom" && entry.entity %>
                    <%= link_to entry.entity_name, classroom_stats_path(entry.entity), class: "font-medium link link-primary" %>
                  <% else %>
                    <span class="font-medium"><%= entry.entity_name %></span>
                  <% end %>
                </div>
                <div class="text-right">
                  <div class="font-bold text-primary text-lg"><%= entry.value %>场</div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 opacity-50">
            <p>本周暂无班级数据</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
