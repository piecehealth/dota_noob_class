<div class="hero min-h-[60vh] bg-base-200">
  <div class="hero-content text-center">
    <div class="max-w-md">
      <h1 class="text-5xl font-bold mb-4">Dota2 萌新班</h1>
      <p class="text-xl opacity-70 mb-6">一起开黑，一起进步</p>
      <div class="flex gap-4 justify-center">
        <%= link_to "查看对局", matches_path, class: "btn btn-primary" %>
        <%= link_to "查看统计", stats_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>

<div class="container mx-auto p-4 mt-8">
  <h2 class="text-2xl font-bold mb-4 text-center">今日活动</h2>
  
  <% if @today_matches&.any? %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <% @today_matches.first(6).each do |match| %>
        <div class="card bg-base-200 shadow-sm <%= match.won ? 'border-l-4 border-success' : 'border-l-4 border-error' %>">
          <div class="card-body p-4">
            <div class="flex items-center gap-4">
              <% if match.hero_id %>
                <%= image_tag hero_image_path(match.hero_id), 
                              alt: hero_name(match.hero_id), 
                              class: "w-12 h-12 rounded mask mask-squircle",
                              onerror: "this.src='/assets/heros/placeholder.svg'" %>
              <% end %>
              <div>
                <h3 class="font-bold"><%= match.user&.name %></h3>
                <p class="text-sm opacity-70">
                  <%= hero_name(match.hero_id) %> · 
                  <%= match.kills %>/<%= match.deaths %>/<%= match.assists %>
                </p>
                <p class="text-xs opacity-50">
                  <%= match.played_at&.strftime("%H:%M") %>
                </p>
              </div>
              <div class="ml-auto">
                <div class="badge <%= match.won ? 'badge-success' : 'badge-error' %>">
                  <%= match.won ? '胜' : '负' %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center opacity-50 py-8">
      <p>今天还没有对局记录</p>
    </div>
  <% end %>
</div>
