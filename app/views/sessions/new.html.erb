<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-full max-w-sm bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold mb-4">登录</h2>

      <% if flash[:alert] %>
        <div role="alert" class="alert alert-error mb-4">
          <span><%= flash[:alert] %></span>
        </div>
      <% end %>

      <%= form_with url: session_path, method: :post do |f| %>
        <fieldset class="fieldset">
          <label class="fieldset-label" for="username">用户名</label>
          <%= f.text_field :username, id: "username", class: "input input-bordered w-full", placeholder: "请输入用户名", required: true, autofocus: true %>
        </fieldset>

        <fieldset class="fieldset mt-3">
          <label class="fieldset-label" for="password">密码</label>
          <%= f.password_field :password, id: "password", class: "input input-bordered w-full", placeholder: "请输入密码", required: true %>
        </fieldset>

        <div class="mt-6">
          <%= f.submit "登录", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
