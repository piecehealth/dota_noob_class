<header class="sticky top-0 z-50 bg-white/85 backdrop-blur-md border-b border-black/5 shadow-sm">
  <div class="navbar max-w-6xl mx-auto px-3 sm:px-6 min-h-12">

    <div class="navbar-start">
      <%= link_to root_path, class: "font-black text-base tracking-tight text-base-content hover:text-primary transition-colors" do %>
        DOTA2 萌新班
      <% end %>
    </div>

    <div class="navbar-end gap-1 sm:gap-2">
      <% if current_user %>
        <span class="text-xs text-base-content/50 hidden sm:block mr-1">
          <%= current_user.display_name %>
        </span>

        <% if current_user.student? %>
          <%= link_to "我的游戏", mine_matches_path, class: "btn btn-ghost btn-xs sm:btn-sm" %>
          <%= link_to "我的复盘", mine_coaching_requests_path, class: "btn btn-ghost btn-xs sm:btn-sm" %>
        <% elsif current_user.coach? %>
          <%= link_to "我的班级", mine_classrooms_path, class: "btn btn-ghost btn-xs sm:btn-sm" %>
          <%= link_to "复盘请求", coaching_requests_path, class: "btn btn-ghost btn-xs sm:btn-sm" %>
        <% end %>

        <%= button_to session_path, method: :delete,
              class: "btn btn-outline btn-error btn-xs sm:btn-sm" do %>
          退出
        <% end %>
      <% else %>
        <%= link_to "登录", new_session_path, class: "btn btn-primary btn-sm" %>
      <% end %>
    </div>

  </div>
</header>
