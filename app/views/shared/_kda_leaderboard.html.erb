<% if entries.any? %>
  <div class="space-y-2">
    <% entries.each do |entry| %>
      <div class="flex items-center gap-3 p-2 bg-base-100 rounded-lg">
        <div class="w-8 h-8 flex items-center justify-center font-bold <%= entry.rank <= 3 ? 'text-warning' : 'opacity-50' %>">
          <%= entry.rank <= 3 ? ["🥇", "🥈", "🥉"][entry.rank - 1] : "##{entry.rank}" %>
        </div>
        <div class="flex-1 min-w-0">
          <% if entry.entity_type == "User" && entry.entity %>
            <%= link_to entry.entity_name, matches_user_path(entry.entity), class: "font-medium truncate block link link-primary" %>
          <% else %>
            <span class="font-medium truncate block"><%= entry.entity_name %></span>
          <% end %>
          <div class="text-xs opacity-50">
            <% if entry.classroom %>
              <%= link_to "#{entry.classroom.name}", classroom_stats_path(entry.classroom), class: "hover:underline" %>
            <% end %>
            <% if entry.group %>
              <%= link_to "#{entry.group.number}组", group_stats_path(entry.group), class: "hover:underline" %>
            <% end %>
            <% if entry.details %>
              · <%= entry.details['kills'] %>/<%= entry.details['deaths'] %>/<%= entry.details['assists'] %>
              (<%= entry.details['match_count'] %>场)
            <% end %>
          </div>
        </div>
        <div class="text-right">
          <div class="font-bold text-success text-lg">
            <% if entry.details %>
              <%= entry.details['kda_formatted'] %>
            <% else %>
              <%= "%.2f" % (entry.value / 100.0) %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-8 opacity-50">
    <p>本周暂无KDA数据</p>
  </div>
<% end %>
