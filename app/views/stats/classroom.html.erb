<div class="container mx-auto p-4">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @classroom.number %>班 统计</h1>
      <p class="text-sm opacity-60">
        <%= @week_start.strftime("%m月%d日") %> - <%= @week_end.strftime("%m月%d日") %>
      </p>
    </div>
    <%= link_to "← 返回对局列表", matches_path, class: "btn btn-ghost btn-sm" %>
  </div>
  
  <!-- Week Navigation -->
  <div class="card bg-base-200 mb-6">
    <div class="card-body py-4">
      <div class="flex items-center justify-between">
        <%= link_to "← 上周", classroom_stats_path(@classroom, week: @week_start - 7.days), class: "btn btn-ghost btn-sm" %>
        <span class="text-lg font-semibold">本周数据</span>
        <%= link_to "下周 →", classroom_stats_path(@classroom, week: @week_start + 7.days), class: "btn btn-ghost btn-sm" %>
      </div>
    </div>
  </div>

  <!-- Total Stats -->
  <div class="stats shadow w-full mb-6">
    <div class="stat bg-primary/10">
      <div class="stat-title">总对局数</div>
      <div class="stat-value text-primary"><%= @total_stats[:matches] %></div>
    </div>
    <div class="stat bg-success/10">
      <div class="stat-title">胜利</div>
      <div class="stat-value text-success"><%= @total_stats[:wins] %></div>
    </div>
    <div class="stat bg-error/10">
      <div class="stat-title">失败</div>
      <div class="stat-value text-error"><%= @total_stats[:losses] %></div>
    </div>
    <div class="stat bg-secondary/10">
      <div class="stat-title">参与人数</div>
      <div class="stat-value text-secondary"><%= @total_stats[:participants] %></div>
    </div>
  </div>

  <!-- Group Stats -->
  <div class="card bg-base-200 mb-6">
    <div class="card-body">
      <h2 class="card-title mb-4">各小组统计</h2>
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead>
            <tr>
              <th>小组</th>
              <th>对局数</th>
              <th>胜/负</th>
              <th>胜率</th>
              <th>成员数</th>
            </tr>
          </thead>
          <tbody>
            <% @group_stats.each do |stat| %>
              <tr class="hover <%= 'opacity-50' if stat[:matches] == 0 %>">
                <td>
                  <%= link_to "#{stat[:group].number}组", group_stats_path(stat[:group], week: @week_start), class: "link link-primary font-medium" %>
                </td>
                <td class="font-medium">
                  <%= stat[:matches] > 0 ? "#{stat[:matches]}场" : "-" %>
                </td>
                <td>
                  <% if stat[:matches] > 0 %>
                    <span class="text-success"><%= stat[:wins] %></span>
                    <span class="opacity-30">/</span>
                    <span class="text-error"><%= stat[:losses] %></span>
                  <% else %>
                    <span class="opacity-30">-</span>
                  <% end %>
                </td>
                <td>
                  <% if stat[:matches] > 0 %>
                    <span class="<%= stat[:win_rate] >= 50 ? 'text-success' : 'text-error' %>"><%= stat[:win_rate] %>%</span>
                  <% else %>
                    <span class="opacity-30">-</span>
                  <% end %>
                </td>
                <td><%= stat[:members] %>人</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Member Stats -->
  <div class="card bg-base-200">
    <div class="card-body">
      <h2 class="card-title mb-4">所有组员对局</h2>
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead>
            <tr>
              <th>玩家</th>
              <th>小组</th>
              <th>对局数</th>
              <th>胜/负</th>
              <th>胜率</th>
              <th>KDA</th>
            </tr>
          </thead>
          <tbody>
            <% @user_stats.each do |stat| %>
              <tr class="hover <%= 'opacity-50' if stat[:matches] == 0 %>">
                <td>
                  <%= link_to stat[:user].display_name, matches_user_path(stat[:user]), class: "link link-primary font-medium" %>
                </td>
                <td>
                  <% if stat[:user].group %>
                    <%= link_to "#{stat[:user].group.number}组", group_stats_path(stat[:user].group, week: @week_start), class: "link link-secondary" %>
                  <% end %>
                </td>
                <td class="font-medium">
                  <%= stat[:matches] > 0 ? "#{stat[:matches]}场" : "-" %>
                </td>
                <td>
                  <% if stat[:matches] > 0 %>
                    <span class="text-success"><%= stat[:wins] %></span>
                    <span class="opacity-30">/</span>
                    <span class="text-error"><%= stat[:losses] %></span>
                  <% else %>
                    <span class="opacity-30">-</span>
                  <% end %>
                </td>
                <td>
                  <% if stat[:matches] > 0 %>
                    <span class="<%= stat[:win_rate] >= 50 ? 'text-success' : 'text-error' %>"><%= stat[:win_rate] %>%</span>
                  <% else %>
                    <span class="opacity-30">-</span>
                  <% end %>
                </td>
                <td class="opacity-70">
                  <%= stat[:matches] > 0 ? stat[:kda] : "-" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
