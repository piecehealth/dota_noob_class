<div class="container mx-auto p-4">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">📊 玩家对比</h1>
    <%= link_to "← 返回统计", stats_path, class: "btn btn-ghost btn-sm" %>
  </div>

  <!-- Player Selection -->
  <div class="card bg-base-200 mb-6">
    <div class="card-body">
      <%= form_with url: compare_stats_path, method: :get, local: true do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <% 3.times do |i| %>
            <fieldset class="fieldset">
              <legend class="fieldset-legend text-sm">玩家 <%= i + 1 %></legend>
              <%= f.select "user_ids[]", 
                  options_for_select(@available_users.map { |u| ["#{u.display_name} (#{u.classroom&.name} #{u.group&.number}组)", u.id] }, 
                  @user_ids[i]),
                  { include_blank: "选择玩家" },
                  class: "select select-bordered w-full" %>
            </fieldset>
          <% end %>
        </div>
        <%= f.submit "开始对比", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <!-- Comparison Results -->
  <% if @comparisons %>
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title mb-4">对比结果 (过去 <%= @days %> 天)</h2>
        <div class="overflow-x-auto">
          <table class="table table-sm">
            <thead>
              <tr>
                <th>玩家</th>
                <th>班级/小组</th>
                <th>段位</th>
                <th>对局数</th>
                <th>胜/负</th>
                <th>胜率</th>
                <th>平均KDA</th>
                <th>段位变化</th>
              </tr>
            </thead>
            <tbody>
              <% @comparisons.each do |comp| %>
                <% progress = comp[:rank_progress] %>
                <tr class="hover">
                  <td>
                    <%= link_to comp[:user].display_name, user_path(comp[:user]), class: "link link-primary font-medium" %>
                  </td>
                  <td class="opacity-70">
                    <%= comp[:user].classroom&.name %> <%= comp[:user].group&.number %>组
                  </td>
                  <td>
                    <span class="badge badge-primary badge-sm whitespace-nowrap"><%= comp[:user].display_rank %></span>
                  </td>
                  <td class="font-medium"><%= comp[:matches_count] %></td>
                  <td>
                    <span class="text-success"><%= comp[:wins] %></span>
                    <span class="opacity-30">/</span>
                    <span class="text-error"><%= comp[:losses] %></span>
                  </td>
                  <td>
                    <span class="<%= comp[:win_rate] >= 50 ? 'text-success' : 'text-error' %>"><%= comp[:win_rate] %>%</span>
                  </td>
                  <td class="opacity-70"><%= comp[:avg_kda] %></td>
                  <td>
                    <% if progress[:change] > 0 %>
                      <span class="text-success font-medium">+<%= progress[:change] %></span>
                    <% elsif progress[:change] < 0 %>
                      <span class="text-error font-medium"><%= progress[:change] %></span>
                    <% else %>
                      <span class="opacity-30">-</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>
