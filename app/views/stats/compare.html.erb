<div class="container mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold">📊 玩家对比</h1>
    <%= link_to "← 返回统计概览", stats_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <!-- Player Selection -->
  <div class="bg-white shadow rounded-lg p-6 mb-8">
    <%= form_with url: compare_stats_path, method: :get, local: true do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
        <% 3.times do |i| %>
          <div>
            <%= f.label "user_ids[]", "玩家 #{i + 1}", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select "user_ids[]", 
                options_for_select(@available_users.map { |u| ["#{u.display_name} (#{u.classroom&.name} #{u.group&.number}组)", u.id] }, 
                @user_ids[i]),
                { include_blank: "选择玩家" },
                class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          </div>
        <% end %>
      </div>
      <div class="flex items-center gap-4">
        <%= f.submit "开始对比", class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition" %>
      </div>
    <% end %>
  </div>

  <!-- Comparison Results -->
  <% if @comparisons %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-xl font-semibold">对比结果 (过去 <%= @days %> 天)</h2>
      </div>
      <table class="min-w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">玩家</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">班级/小组</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">段位</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">对局数</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">胜/负</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">胜率</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">平均KDA</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">段位变化</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @comparisons.each do |comp| %>
            <% progress = comp[:rank_progress] %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4">
                <%= link_to comp[:user].display_name, user_path(comp[:user]), class: "text-blue-600 hover:text-blue-800 font-medium" %>
              </td>
              <td class="px-6 py-4 text-gray-600">
                <%= comp[:user].classroom&.name %> <%= comp[:user].group&.number %>组
              </td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  <%= comp[:user].display_rank %>
                </span>
              </td>
              <td class="px-6 py-4 font-medium"><%= comp[:matches_count] %></td>
              <td class="px-6 py-4">
                <span class="text-green-600"><%= comp[:wins] %></span>
                <span class="text-gray-400">/</span>
                <span class="text-red-600"><%= comp[:losses] %></span>
              </td>
              <td class="px-6 py-4">
                <span class="<%= comp[:win_rate] >= 50 ? 'text-green-600' : 'text-red-600' %>">
                  <%= comp[:win_rate] %>
                </span>
              </td>
              <td class="px-6 py-4 text-gray-600"><%= comp[:avg_kda] %></td>
              <td class="px-6 py-4">
                <% if progress[:change] > 0 %>
                  <span class="text-green-600 font-medium">+<%= progress[:change] %></span>
                  <span class="text-xs text-gray-500 block">
                    <%= comp[:user].display_rank %>
                  </span>
                <% elsif progress[:change] < 0 %>
                  <span class="text-red-600 font-medium"><%= progress[:change] %></span>
                <% else %>
                  <span class="text-gray-400">-</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
