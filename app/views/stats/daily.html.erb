<div class="container mx-auto p-4">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">🏆 每日排行</h1>
    <%= link_to "← 返回统计", stats_path(date: @date), class: "btn btn-ghost btn-sm" %>
  </div>
  
  <!-- Date Navigation -->
  <div class="card bg-base-200 mb-6">
    <div class="card-body py-4">
      <div class="flex items-center justify-between">
        <%= link_to "← 前一天", daily_stats_path(date: @date - 1.day), class: "btn btn-ghost btn-sm" %>
        <span class="text-lg font-semibold"><%= @date.strftime("%Y年%m月%d日") %></span>
        <%= link_to "后一天 →", daily_stats_path(date: @date + 1.day), class: "btn btn-ghost btn-sm" %>
      </div>
    </div>
  </div>

  <!-- Stats Table -->
  <div class="card bg-base-200">
    <div class="card-body">
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead>
            <tr>
              <th>排名</th>
              <th>玩家</th>
              <th>班级/小组</th>
              <th>段位</th>
              <th>对局数</th>
              <th>胜/负</th>
              <th>胜率</th>
              <th>KDA</th>
              <th>段位变化</th>
            </tr>
          </thead>
          <tbody>
            <% @stats.each_with_index do |stat, index| %>
              <tr class="hover">
                <td>
                  <% if index < 3 %>
                    <span class="text-2xl"><%= ["🥇", "🥈", "🥉"][index] %></span>
                  <% else %>
                    <span class="opacity-50 font-medium">#<%= index + 1 %></span>
                  <% end %>
                </td>
                <td>
                  <%= link_to stat.user.display_name, user_path(stat.user), class: "link link-primary font-medium" %>
                </td>
                <td class="opacity-70">
                  <%= stat.user.classroom&.name %> <%= stat.user.group&.number %>组
                </td>
                <td>
                  <span class="badge badge-primary badge-sm"><%= stat.user.display_rank %></span>
                </td>
                <td class="font-medium"><%= stat.matches_count %></td>
                <td>
                  <span class="text-success"><%= stat.wins_count %></span>
                  <span class="opacity-30">/</span>
                  <span class="text-error"><%= stat.losses_count %></span>
                </td>
                <td>
                  <span class="<%= stat.win_rate >= 50 ? 'text-success' : 'text-error' %>"><%= stat.win_rate %>%</span>
                </td>
                <td class="opacity-70"><%= stat.avg_kda %></td>
                <td>
                  <% if stat.rank_change > 0 %>
                    <span class="text-success font-medium">+<%= stat.rank_change %></span>
                  <% elsif stat.rank_change < 0 %>
                    <span class="text-error font-medium"><%= stat.rank_change %></span>
                  <% else %>
                    <span class="opacity-30">-</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  
  <% if @stats.empty? %>
    <div class="card bg-base-200 mt-6">
      <div class="card-body text-center py-12">
        <p class="text-lg opacity-70">暂无数据</p>
        <p class="text-sm opacity-50 mt-2">该日期没有玩家进行对局</p>
      </div>
    </div>
  <% end %>
</div>
