<div class="container mx-auto p-4">
  <h1 class="text-2xl font-bold mb-4">📊 数据统计</h1>

  <!-- Daily Stats -->
  <div class="card bg-base-200 mb-6">
    <div class="card-body">
      <h2 class="card-title mb-4"><%= @date.strftime('%Y-%m-%d') %> 数据</h2>
      
      <% if @daily_stats.any? %>
        <div class="overflow-x-auto">
          <table class="table table-sm">
            <thead>
              <tr>
                <th>玩家</th>
                <th>对局</th>
                <th>胜率</th>
                <th>平均KDA</th>
                <th>段位变化</th>
              </tr>
            </thead>
            <tbody>
              <% @daily_stats.each do |stat| %>
                <tr>
                  <td><%= stat.user.display_name || stat.user.username %></td>
                  <td><%= stat.matches_count %></td>
                  <td>
                    <% if stat.matches_count > 0 %>
                      <%= number_to_percentage(stat.win_rate * 100, precision: 1) %>
                    <% else %>
                      N/A
                    <% end %>
                  </td>
                  <td><%= stat.avg_kda %></td>
                  <td>
                    <% if stat.rank_change > 0 %>
                      <span class="text-success">+<%= stat.rank_change %></span>
                    <% elsif stat.rank_change < 0 %>
                      <span class="text-error"><%= stat.rank_change %></span>
                    <% else %>
                      -
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="opacity-50 text-center py-8">暂无数据</p>
      <% end %>
    </div>
  </div>

  <!-- Rank Distribution -->
  <div class="card bg-base-200">
    <div class="card-body">
      <h2 class="card-title">📈 段位分布</h2>
      <div class="flex flex-wrap gap-2 mt-4">
        <% @rank_distribution.each do |tier, count| %>
          <div class="badge badge-lg badge-primary">
            <%= tier %>: <%= count %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
