<div class="container mx-auto p-4">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">🏆 段位分布</h1>
    <%= link_to "← 返回统计", stats_path, class: "btn btn-ghost btn-sm" %>
  </div>

  <!-- Rank Distribution Summary -->
  <div class="card bg-base-200 mb-6">
    <div class="card-body">
      <h2 class="card-title mb-4">段位统计</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3">
        <% tier_order = ["先锋", "卫士", "中军", "统帅", "传奇", "万古", "超凡", "冠绝"] %>
        <% tier_order.each do |tier_name| %>
          <% count = @rank_distribution[tier_name] || 0 %>
          <div class="stat bg-base-100 rounded-lg <%= 'ring-2 ring-primary' if count > 0 %>">
            <div class="stat-title text-xs"><%= tier_name %></div>
            <div class="stat-value text-2xl <%= count > 0 ? 'text-primary' : 'opacity-30' %>"><%= count %></div>
            <div class="stat-desc text-xs">人</div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Users by Tier -->
  <% tier_order.each do |tier_name| %>
    <% users = @users_by_tier[tier_order.index(tier_name) + 1] || [] %>
    <% next if users.empty? %>
    
    <div class="card bg-base-200 mb-6">
      <div class="card-body">
        <h2 class="card-title mb-4">
          <%= tier_name %>
          <span class="text-sm font-normal opacity-50">(<%= users.count %>人)</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
          <% users.sort_by(&:current_rank).reverse.each do |user| %>
            <div class="flex items-center gap-3 p-3 bg-base-100 rounded-lg hover:bg-base-300 transition">
              <div class="flex-1 min-w-0">
                <%= link_to user.display_name, user_path(user), class: "font-medium link link-primary truncate block" %>
                <p class="text-sm opacity-50 truncate">
                  <%= user.classroom&.name %> <%= user.group&.number %>组
                </p>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium"><%= user.display_rank %></p>
                <p class="text-xs opacity-50">胜率 <%= user.win_rate %>%</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
