<div class="container mx-auto p-4">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">⭐ 明星学员</h1>
    <%= link_to "← 返回统计", stats_path, class: "btn btn-ghost btn-sm" %>
  </div>
  
  <p class="text-sm opacity-70 mb-6">
    过去 <%= ((Time.current - @since) / 1.day).round %> 天内段位提升最快的学员
  </p>

  <!-- Star Students Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @star_students.each_with_index do |star, index| %>
      <div class="card bg-base-200 overflow-hidden">
        <!-- Header with rank badge -->
        <div class="bg-gradient-to-r from-warning to-accent px-6 py-4">
          <div class="flex items-center gap-3">
            <span class="text-3xl"><%= ["🥇", "🥈", "🥉"][index] || "#{index + 1}" %></span>
            <div>
              <h3 class="font-bold text-lg"><%= star[:user].display_name %></h3>
              <p class="text-sm opacity-80">
                <%= star[:user].classroom&.name %> <%= star[:user].group&.number %>组
              </p>
            </div>
          </div>
        </div>
        
        <!-- Stats -->
        <div class="card-body">
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div class="stat bg-base-100 rounded-lg">
              <div class="stat-value text-success text-2xl">+<%= star[:rank_improvement] %></div>
              <div class="stat-title text-xs">段位提升</div>
            </div>
            <div class="stat bg-base-100 rounded-lg">
              <div class="stat-value text-primary text-2xl"><%= star[:days_tracked] %></div>
              <div class="stat-title text-xs">追踪天数</div>
            </div>
          </div>
          
          <div class="flex items-center justify-between pt-4 border-t border-base-300">
            <div>
              <p class="text-sm opacity-50">当前段位</p>
              <p class="font-medium"><%= star[:user].display_rank %></p>
            </div>
            <%= link_to "查看详情", user_path(star[:user]), class: "link link-primary text-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  
  <% if @star_students.empty? %>
    <div class="card bg-base-200 text-center py-12">
      <div class="card-body">
        <p class="text-4xl mb-4">📊</p>
        <p class="text-lg opacity-70">暂无数据</p>
        <p class="text-sm opacity-50 mt-2">还没有学员在这段时间内提升段位</p>
      </div>
    </div>
  <% end %>
</div>
