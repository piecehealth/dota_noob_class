<div class="container mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold">⭐ 明星学员</h1>
    <%= link_to "← 返回统计概览", stats_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>
  
  <p class="text-gray-600 mb-6">
    过去 <%= ((Time.current - @since) / 1.day).round %> 天内段位提升最快的学员
  </p>

  <!-- Star Students Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @star_students.each_with_index do |star, index| %>
      <div class="bg-white shadow rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
        <!-- Header with rank badge -->
        <div class="bg-gradient-to-r from-yellow-400 to-yellow-500 px-6 py-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="text-3xl"><%= ["🥇", "🥈", "🥉"][index] || "#{index + 1}" %></span>
              <div>
                <h3 class="font-bold text-white text-lg"><%= star[:user].display_name %></h3>
                <p class="text-yellow-100 text-sm">
                  <%= star[:user].classroom&.name %> <%= star[:user].group&.number %>组
                </p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Stats -->
        <div class="p-6">
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div class="text-center p-3 bg-green-50 rounded-lg">
              <p class="text-2xl font-bold text-green-600">+<%= star[:rank_improvement] %></p>
              <p class="text-sm text-green-700">段位提升</p>
            </div>
            <div class="text-center p-3 bg-blue-50 rounded-lg">
              <p class="text-2xl font-bold text-blue-600"><%= star[:days_tracked] %></p>
              <p class="text-sm text-blue-700">追踪天数</p>
            </div>
          </div>
          
          <div class="flex items-center justify-between pt-4 border-t border-gray-100">
            <div>
              <p class="text-sm text-gray-500">当前段位</p>
              <p class="font-medium text-gray-900"><%= star[:user].display_rank %></p>
            </div>
            <%= link_to "查看详情", user_path(star[:user]), class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  
  <% if @star_students.empty? %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <p class="text-4xl mb-4">📊</p>
      <p class="text-lg text-gray-500">暂无数据</p>
      <p class="mt-2 text-gray-400">还没有学员在这段时间内提升段位</p>
    </div>
  <% end %>
</div>
