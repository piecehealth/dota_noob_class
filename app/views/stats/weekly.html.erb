<div class="container mx-auto p-4">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">📊 周报</h1>
    <%= link_to "← 返回统计", stats_path, class: "btn btn-ghost btn-sm" %>
  </div>
  
  <p class="text-sm opacity-70 mb-6"><%= @report[:period] %></p>

  <!-- Stats Summary -->
  <div class="stats stats-vertical sm:stats-horizontal shadow w-full mb-6">
    <div class="stat">
      <div class="stat-title">总对局数</div>
      <div class="stat-value text-primary"><%= @report[:total_matches] %></div>
    </div>
    <div class="stat">
      <div class="stat-title">活跃玩家</div>
      <div class="stat-value text-secondary"><%= @report[:unique_players] %></div>
    </div>
    <div class="stat">
      <div class="stat-title">总胜利</div>
      <div class="stat-value text-success"><%= @report[:daily_breakdown].sum { |d| d[:wins] } %></div>
    </div>
    <div class="stat">
      <div class="stat-title">总失败</div>
      <div class="stat-value text-error"><%= @report[:daily_breakdown].sum { |d| d[:losses] } %></div>
    </div>
  </div>

  <!-- Daily Breakdown -->
  <div class="card bg-base-200">
    <div class="card-body">
      <h2 class="card-title mb-4">每日详情</h2>
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead>
            <tr>
              <th>日期</th>
              <th>对局数</th>
              <th>活跃玩家</th>
              <th>胜利</th>
              <th>失败</th>
              <th>胜率</th>
            </tr>
          </thead>
          <tbody>
            <% @report[:daily_breakdown].each do |day| %>
              <tr class="hover">
                <td>
                  <%= link_to day[:date].strftime("%m月%d日"), daily_stats_path(date: day[:date]), class: "link link-primary" %>
                  <span class="text-xs opacity-50 ml-2"><%= %w[周日 周一 周二 周三 周四 周五 周六][day[:date].wday] %></span>
                </td>
                <td><%= day[:matches_count] %></td>
                <td><%= day[:unique_players] %></td>
                <td class="text-success"><%= day[:wins] %></td>
                <td class="text-error"><%= day[:losses] %></td>
                <td>
                  <% win_rate = day[:matches_count] > 0 ? (day[:wins].to_f / day[:matches_count] * 100).round(1) : 0 %>
                  <span class="<%= win_rate >= 50 ? 'text-success' : 'text-error' %>"><%= win_rate %>%</span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Week Navigation -->
  <div class="flex justify-between mt-6">
    <%= link_to "← 上周", weekly_stats_path(end_date: @end_date - 7.days), class: "btn btn-outline btn-sm" %>
    <%= link_to "下周 →", weekly_stats_path(end_date: @end_date + 7.days), class: "btn btn-outline btn-sm" %>
  </div>
</div>
