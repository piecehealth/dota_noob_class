<div class="container mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold">📊 周报</h1>
    <%= link_to "← 返回统计概览", stats_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>
  
  <p class="text-gray-600 mb-6"><%= @report[:period] %></p>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-gray-500 text-sm font-medium">总对局数</h3>
      <p class="text-3xl font-bold text-blue-600"><%= @report[:total_matches] %></p>
    </div>
    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-gray-500 text-sm font-medium">活跃玩家</h3>
      <p class="text-3xl font-bold text-purple-600"><%= @report[:unique_players] %></p>
    </div>
    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-gray-500 text-sm font-medium">总胜利</h3>
      <p class="text-3xl font-bold text-green-600"><%= @report[:daily_breakdown].sum { |d| d[:wins] } %></p>
    </div>
    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-gray-500 text-sm font-medium">总失败</h3>
      <p class="text-3xl font-bold text-red-600"><%= @report[:daily_breakdown].sum { |d| d[:losses] } %></p>
    </div>
  </div>

  <!-- Daily Breakdown -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-xl font-semibold">每日详情</h2>
    </div>
    <table class="min-w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">日期</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">对局数</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">活跃玩家</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">胜利</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">失败</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">胜率</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @report[:daily_breakdown].each do |day| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 font-medium">
              <%= link_to day[:date].strftime("%m月%d日"), daily_stats_path(date: day[:date]), class: "text-blue-600 hover:text-blue-800" %>
              <span class="text-gray-400 text-sm ml-2"><%= %w[周日 周一 周二 周三 周四 周五 周六][day[:date].wday] %></span>
            </td>
            <td class="px-6 py-4"><%= day[:matches_count] %></td>
            <td class="px-6 py-4"><%= day[:unique_players] %></td>
            <td class="px-6 py-4 text-green-600"><%= day[:wins] %></td>
            <td class="px-6 py-4 text-red-600"><%= day[:losses] %></td>
            <td class="px-6 py-4">
              <% win_rate = day[:matches_count] > 0 ? (day[:wins].to_f / day[:matches_count] * 100).round(1) : 0 %>
              <span class="<%= win_rate >= 50 ? 'text-green-600' : 'text-red-600' %>">
                <%= win_rate %>
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Week Navigation -->
  <div class="mt-6 flex items-center justify-between">
    <%= link_to "← 上周", weekly_stats_path(end_date: @end_date - 7.days), class: "text-blue-600 hover:text-blue-800" %>
    <%= link_to "下周 →", weekly_stats_path(end_date: @end_date + 7.days), class: "text-blue-600 hover:text-blue-800" %>
  </div>
</div>
