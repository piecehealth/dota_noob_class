<div class="py-6 px-3 sm:px-6">
  <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">
    <div class="p-4 sm:p-8">
      <div class="flex items-center gap-3 mb-6">
        <%= link_to "←", :back, class: "btn btn-ghost btn-sm" %>
        <div>
          <h1 class="text-2xl font-bold"><%= @student.display_name %></h1>
          <p class="text-xs text-base-content/40 font-mono">Player ID: <%= @student.dota2_player_id %></p>
        </div>
      </div>

      <%= render "matches/match_list", matches: @matches %>
      <%= paginate @matches %>
    </div>
  </div>
</div>
