<div class="container mx-auto p-4">
  <!-- Header -->
  <div class="flex items-center gap-3 mb-6">
    <%= link_to "←", :back, class: "btn btn-ghost btn-sm" %>
    <div>
      <h1 class="text-2xl font-bold"><%= @student.display_name %></h1>
      <p class="text-xs opacity-50 font-mono">Player ID: <%= @student.dota2_player_id %></p>
    </div>
  </div>

  <!-- Match List Card -->
  <div class="card bg-base-200">
    <div class="card-body">
      <%= render "matches/match_list", matches: @matches %>
    </div>
  </div>

  <%= paginate @matches %>
</div>
